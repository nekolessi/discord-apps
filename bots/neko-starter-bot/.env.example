# Discord credentials
DISCORD_TOKEN=your-bot-token
DISCORD_CLIENT_ID=your-application-id # Required for command registration
DISCORD_GUILD_ID=your-guild-id # Required for guild-scoped registration


# Environment
NODE_ENV=development


# Logging
LOG_PRETTY=true # pretty console logs in dev
LOG_LEVEL=info # pino level (trace|debug|info|warn|error|fatal)