{
  "name": "discord-bot-repo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.12.2",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts register.ts --format esm --out-dir dist --clean --sourcemap",
    "start": "node --enable-source-maps dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "pnpm typecheck && pnpm lint",
    "register:guild": "tsx register.ts --scope guild",
    "register:global": "tsx register.ts --scope global",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write ."
  },
  "dependencies": {
    "discord.js": "^14.16.0",
    "dotenv": "^16.4.5",
    "pino": "^9.3.2",
    "pino-pretty": "^11.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.5.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-import": "^2.29.1",
    "globals": "^16.3.0",
    "prettier": "^3.3.3",
    "tsup": "^8.2.4",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.41.0"
  },
  "pnpm": {
    "overrides": {
      "glob@>=10.2.0 <10.5.0": ">=10.5.0",
      "lodash@>=4.0.0 <=4.17.22": ">=4.17.23",
      "undici@<6.23.0": ">=6.23.0",
      "js-yaml@>=4.0.0 <4.1.1": ">=4.1.1",
      "minimatch@<3.1.3": ">=3.1.3",
      "minimatch@>=9.0.0 <9.0.6": ">=9.0.6",
      "rollup@>=4.0.0 <4.59.0": ">=4.59.0",
      "minimatch@>=9.0.0 <9.0.7": ">=9.0.7",
      "minimatch@<3.1.4": ">=3.1.4",
      "ajv@<6.14.0": ">=6.14.0",
      "eslint-plugin-import>minimatch": "9.0.9"
    }
  }
}
