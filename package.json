{
  "name": "discord-apps",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.12.2",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter \"./bots/neko-starter-bot\" dev",
    "build": "pnpm -r --filter \"./bots/*\" build",
    "lint": "pnpm -r --filter \"./bots/*\" lint",
    "typecheck": "pnpm -r --filter \"./bots/*\" typecheck",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run build",
    "format": "pnpm -r --filter \"./bots/*\" format",
    "new:bot": "node scripts/new-bot.mjs"
  },
  "pnpm": {
    "overrides": {
      "glob@>=10.2.0 <10.5.0": ">=10.5.0",
      "lodash@>=4.0.0 <=4.17.22": ">=4.17.23",
      "undici@<6.24.0": "6.24.0",
      "undici@>=7.0.0 <7.24.0": "7.24.0",
      "js-yaml@>=4.0.0 <4.1.1": ">=4.1.1",
      "minimatch@<3.1.3": ">=3.1.3",
      "minimatch@>=9.0.0 <9.0.6": ">=9.0.6",
      "rollup@>=4.0.0 <4.59.0": ">=4.59.0",
      "minimatch@>=9.0.0 <9.0.7": ">=9.0.7",
      "minimatch@<3.1.4": ">=3.1.4",
      "ajv@<6.14.0": ">=6.14.0",
      "flatted@<=3.4.1": "3.4.2",
      "eslint-plugin-import>minimatch": "9.0.9"
    }
  }
}
